  m_ItemImage: {fileID: 0}
  m_Value: 0
  m_MultiSelect: 0
  m_Options:
    m_Options:
    - m_Text: Cuz we lost everything
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: We had to pay the price
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: 
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: I saw in you what life was missing
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: you lit a flame that consumed my hate
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: I'm not one for reminiscing but
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: I'd trade it all for your sweet embrace
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: 
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: cause we lost everything
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: we had to pay the price
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: 
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: there's a canvas with two faces
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: of fallen angels who loved and lost
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: it was a passion for the ages
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
    - m_Text: and in the end guess we paid the cost
      m_Image: {fileID: 0}
      m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_OnValueChanged:
    m_PersistentCalls:
      m_Calls: []
